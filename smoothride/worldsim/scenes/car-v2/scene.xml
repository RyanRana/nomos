<mujoco model="car-v2">
  <!--
    car-v2 = car-v1's validated Newtonian dynamics + a real lofted car-body MESH.

    Physics is UNCHANGED from car-v1: the box `chassis_col` carries the mass and
    inertia and the four cylinder wheels collide + roll. The car SHAPE is a
    non-colliding visual mesh (`car_body.obj`, body-only) overlaid on the box, so
    Newton sees the same stable RWD Ackermann car while the renderer sees a sedan.
    Mesh generated by: python -m smoothride.worldsim.assets.car_mesh

    CONTROL CONTRACT (unchanged, action order == <actuator> order):
        action = [drive_rl, drive_rr, steer_l, steer_r]
    STATE READBACK (unchanged): get_object_state("chassis") + chassis_* sensors.
  -->
  <compiler angle="radian" autolimits="true" meshdir="../../assets/meshes"/>
  <option gravity="0 0 -9.81" timestep="0.004" integrator="implicitfast"/>

  <default>
    <joint damping="0.2"/>
    <geom condim="4" friction="1.3 0.02 0.001"/>
    <default class="wheel">
      <geom type="cylinder" size="0.33 0.12" euler="1.5708 0 0" rgba="0.07 0.07 0.09 1"
            friction="1.6 0.02 0.001" mass="15"/>
    </default>
    <!-- visual-only: no collision, no mass; just drawn -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" mass="0"/>
    </default>
  </default>

  <asset>
    <texture name="sky" type="skybox" builtin="gradient" rgb1="0.55 0.72 0.92"
             rgb2="0.13 0.17 0.24" width="256" height="256"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.25 0.27 0.30" rgb2="0.20 0.22 0.25"
             width="128" height="128"/>
    <material name="asphalt" texture="grid" texrepeat="40 40" reflectance="0.05"/>
    <material name="car_body" rgba="0.20 0.55 0.85 1" specular="0.7" shininess="0.6" reflectance="0.1"/>
    <mesh name="car_body_mesh" file="car_body.obj"/>
  </asset>

  <worldbody>
    <light name="sun" pos="10 -10 20" dir="-0.4 0.4 -1" diffuse="0.9 0.9 0.85"
           specular="0.3 0.3 0.3" castshadow="true"/>
    <geom name="floor" type="plane" size="120 120 0.1" material="asphalt"/>
    <camera name="overhead" pos="0 0 40" xyaxes="1 0 0 0 1 0"/>

    <body name="chassis" pos="0 0 0.45">
      <freejoint name="chassis_joint"/>
      <!-- inertia + collision (hidden: group 3) -->
      <geom name="chassis_col" type="box" size="2.1 0.85 0.22" mass="1100"
            group="3" rgba="0.2 0.55 0.85 0"/>
      <geom name="cabin_col" type="box" size="1.1 0.78 0.25" pos="-0.2 0 0.42" mass="120"
            group="3" rgba="0 0 0 0"/>
      <!-- the car shape: visual mesh overlay -->
      <geom name="body_mesh" class="visual" type="mesh" mesh="car_body_mesh" material="car_body"/>
      <camera name="chase" pos="-9 0 3.5" xyaxes="0 -1 0 0.35 0 1" mode="trackcom"/>

      <body name="steer_fl" pos="1.35 0.85 -0.1">
        <inertial pos="0 0 0" mass="2" diaginertia="0.05 0.05 0.05"/>
        <joint name="steer_l" type="hinge" axis="0 0 1" range="-0.7 0.7"/>
        <body name="wheel_fl"><joint name="roll_fl" type="hinge" axis="0 1 0"/><geom class="wheel"/></body>
      </body>
      <body name="steer_fr" pos="1.35 -0.85 -0.1">
        <inertial pos="0 0 0" mass="2" diaginertia="0.05 0.05 0.05"/>
        <joint name="steer_r" type="hinge" axis="0 0 1" range="-0.7 0.7"/>
        <body name="wheel_fr"><joint name="roll_fr" type="hinge" axis="0 1 0"/><geom class="wheel"/></body>
      </body>
      <body name="wheel_rl" pos="-1.35 0.85 -0.1"><joint name="roll_rl" type="hinge" axis="0 1 0"/><geom class="wheel"/></body>
      <body name="wheel_rr" pos="-1.35 -0.85 -0.1"><joint name="roll_rr" type="hinge" axis="0 1 0"/><geom class="wheel"/></body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="drive_rl" joint="roll_rl" kv="120" ctrlrange="-40 80"/>
    <velocity name="drive_rr" joint="roll_rr" kv="120" ctrlrange="-40 80"/>
    <position name="steer_l"  joint="steer_l" kp="2000" ctrlrange="-0.7 0.7"/>
    <position name="steer_r"  joint="steer_r" kp="2000" ctrlrange="-0.7 0.7"/>
  </actuator>

  <sensor>
    <framepos    name="chassis_pos" objtype="body" objname="chassis"/>
    <framequat   name="chassis_quat" objtype="body" objname="chassis"/>
    <framelinvel name="chassis_linvel" objtype="body" objname="chassis"/>
    <framezaxis  name="chassis_up" objtype="body" objname="chassis"/>
  </sensor>
</mujoco>
